{
  "name": "@ds/tokens",
  "version": "0.1.0",
  "description": "Design tokens (fonte: Figma Variables) compilados via Style Dictionary",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./css": "./build/tokens.css"
  },
  "files": ["build"],
  "scripts": {
    "build": "style-dictionary build --config style-dictionary.config.js",
    "clean": "rm -rf build"
  },
  "devDependencies": {
    "style-dictionary": "^4.3.0"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": ["{projectRoot}/build"]
      }
    }
  }
}
