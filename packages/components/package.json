{
  "name": "@ds/components",
  "version": "0.1.0",
  "description": "Web Components do Design System (Stencil)",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/ds-components/ds-components.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./components/*.js": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./dist/components/*.js": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js"
    },
    "./css": "./dist/ds-components/ds-components.css"
  },
  "files": ["dist", "loader"],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll"
  },
  "dependencies": {
    "@ds/tokens": "0.1.0"
  },
  "devDependencies": {
    "@stencil/core": "^4.22.3",
    "@stencil/react-output-target": "^0.7.1",
    "@stencil/angular-output-target": "^0.10.1",
    "@stencil/vue-output-target": "^0.9.0",
    "@axe-core/puppeteer": "^4.10.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "puppeteer": "^23.0.0"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": ["{projectRoot}/dist", "{projectRoot}/loader"],
        "dependsOn": ["^build"]
      }
    }
  }
}
